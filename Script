-- Função para limpar uma seção
local function clearSection(section, elementsTable)
    if not section or not section.Container then return {} end
    for _, element in pairs(elementsTable) do
        pcall(function() element:Destroy() end)
    end
    for _, child in pairs(section.Container:GetChildren()) do
        pcall(function()
            if child:IsA("Frame") or child:IsA("TextLabel") or child:IsA("TextBox") or child:IsA("TextButton") then
                child:Destroy()
            end
        end)
    end
    return {}
end

-- Função para atualizar as propriedades de uma instância selecionada
local function updateProperties(instance)
    if not PropertiesSection then return end
    propertyElements = clearSection(PropertiesSection, propertyElements)

    if not instance then return end

    PropertiesSection:CreateLabel({Name = "Instância: " .. instance.Name .. " (" .. instance.ClassName .. ")"})
    PropertiesSection:CreateLabel({Name = "Parent: " .. (instance.Parent and instance.Parent.Name or "nil")})

    local propertiesToEdit = {
        "Name", "Archivable", "CanCollide", "Transparency", "Anchored", "Locked",
        "Position", "Size", "Color", "BrickColor", "Material", "Reflectance", "Transparency"
    }

    for _, propName in ipairs(propertiesToEdit) do
        local success, value = pcall(function() return instance[propName] end)
        if success then
            local propType = typeof(value)
            local displayValue = tostring(value)

            if propType == "boolean" then
                local toggle = PropertiesSection:CreateToggle({
                    Name = propName,
                    CurrentValue = value,
                    Callback = function(newValue)
                        pcall(function() instance[propName] = newValue end)
                    end
                })
                table.insert(propertyElements, toggle)
            elseif propType == "string" or propType == "number" then
                local input = PropertiesSection:CreateInput({
                    Name = propName,
                    CurrentValue = tostring(value),
                    PlaceholderText = "Editar " .. propName,
                    Callback = function(newValueStr)
                        local convertedValue = newValueStr
                        if propType == "number" then
                            convertedValue = tonumber(newValueStr)
                            if not convertedValue then return end
                        end
                        pcall(function() instance[propName] = convertedValue end)
                    end
                })
                table.insert(propertyElements, input)
            elseif propType == "Color3" then
                local colorPicker = PropertiesSection:CreateColorPicker({
                    Name = propName,
                    Color = value,
                    Callback = function(newColor)
                        pcall(function() instance[propName] = newColor end)
                    end
                })
                table.insert(propertyElements, colorPicker)
            elseif propType == "Vector3" then
                PropertiesSection:CreateLabel({Name = propName .. ":"})
                local inputX = PropertiesSection:CreateInput({
                    Name = "X", CurrentValue = tostring(value.X), PlaceholderText = "X",
                    Callback = function(newXStr)
                        local newX = tonumber(newXStr)
                        if newX then pcall(function() instance[propName] = Vector3.new(newX, value.Y, value.Z) end) end
                    end
                })
                local inputY = PropertiesSection:CreateInput({
                    Name = "Y", CurrentValue = tostring(value.Y), PlaceholderText = "Y",
                    Callback = function(newYStr)
                        local newY = tonumber(newYStr)
                        if newY then pcall(function() instance[propName] = Vector3.new(value.X, newY, value.Z) end) end
                    end
                })
                local inputZ = PropertiesSection:CreateInput({
                    Name = "Z", CurrentValue = tostring(value.Z), PlaceholderText = "Z",
                    Callback = function(newZStr)
                        local newZ = tonumber(newZStr)
                        if newZ then pcall(function() instance[propName] = Vector3.new(value.X, value.Y, newZ) end) end
                    end
                })
                table.insert(propertyElements, inputX)
                table.insert(propertyElements, inputY)
                table.insert(propertyElements, inputZ)
            else
                PropertiesSection:CreateLabel({Name = propName .. ": " .. displayValue})
            end
        end
    end
end

-- Função para atualizar as ações rápidas
local function updateActions(instance)
    if not ActionsSection then return end
    actionElements = clearSection(ActionsSection, actionElements)

    if not instance or instance == game then return end

    local destroyButton = ActionsSection:CreateButton({
        Name = "Destroy Instância",
        Callback = function()
            local success, err = pcall(function() instance:Destroy() end)
            if success then
                Rayfield:Notify({
                    Title = "Sucesso", Content = "Instância destruída: " .. instance.Name, Duration = 3
                })
                currentInstance = game
                updateHierarchy(game)
                updateProperties(game)
                updateActions(game)
            else
                Rayfield:Notify({
                    Title = "Erro", Content = "Falha ao destruir: " .. (err or "Erro desconhecido"), Duration = 5
                })
            end
        end
    })
    table.insert(actionElements, destroyButton)

    local cloneButton = ActionsSection:CreateButton({
        Name = "Clonar Instância",
        Callback = function()
            local success, clonedInstance = pcall(function() return instance:Clone() end)
            if success and clonedInstance then
                clonedInstance.Parent = game.Workspace
                Rayfield:Notify({
                    Title = "Sucesso", Content = "Instância clonada: " .. clonedInstance.Name, Duration = 3
                })
                updateHierarchy(currentInstance)
            else
                Rayfield:Notify({
                    Title = "Erro", Content = "Falha ao clonar: " .. (clonedInstance or "Erro desconhecido"), Duration = 5
                })
            end
        end
    })
    table.insert(actionElements, cloneButton)

    local copyPathButton = ActionsSection:CreateButton({
        Name = "Copiar Caminho",
        Callback = function()
            local path = instance:GetFullName()
            local successClipboard, errClipboard = pcall(function() setclipboard(path) end)
            if successClipboard then
                Rayfield:Notify({
                    Title = "Caminho Copiado", Content = path, Duration = 3
                })
            else
                Rayfield:Notify({
                    Title = "Erro", Content = "Falha ao copiar para a área de transferência: " .. (errClipboard or "Recurso não disponível."), Duration = 5
                })
            end
        end
    })
    table.insert(actionElements, copyPathButton)
end

-- Função para atualizar a hierarquia
local function updateHierarchy(instance)
    if not ExplorerSection then return end
    explorerElements = clearSection(ExplorerSection, explorerElements)

    if instance.Parent then
        local backButton = ExplorerSection:CreateButton({
            Name = "<- Voltar para " .. instance.Parent.Name,
            Callback = function()
                currentInstance = instance.Parent
                updateHierarchy(currentInstance)
                updateProperties(currentInstance)
                updateActions(currentInstance)
            end
        })
        table.insert(explorerElements, backButton)
    end

    local children = instance:GetChildren()
    for i = 1, math.min(#children, 200) do -- Aumentado limite para 200 para testes
        local child = children[i]
        local button = ExplorerSection:CreateButton({
            Name = child.Name .. " (" .. child.ClassName .. ")",
            Callback = function()
                currentInstance = child
                updateHierarchy(child)
                updateProperties(child)
                updateActions(child)
            end
        })
        table.insert(explorerElements, button)
    end
end

-- Função de busca
local function searchInstances(searchText)
    if not ExplorerSection then return end
    explorerElements = clearSection(ExplorerSection, explorerElements)

    if searchText == "" then
        updateHierarchy(game)
        updateProperties(game)
        updateActions(game)
        return
    end

    local foundInstances = {}
    local function recursiveSearch(instance)
        if instance.Name:lower():find(searchText:lower()) or instance.ClassName:lower():find(searchText:lower()) then
            table.insert(foundInstances, instance)
        end
        for _, child in pairs(instance:GetChildren()) do
            recursiveSearch(child)
        end
    end
    recursiveSearch(game)

    if #foundInstances > 0 then
        for _, foundInstance in ipairs(foundInstances) do
            local button = ExplorerSection:CreateButton({
                Name = foundInstance.Name .. " (" .. foundInstance.ClassName .. ")",
                Callback = function()
                    currentInstance = foundInstance
                    updateHierarchy(foundInstance)
                    updateProperties(foundInstance)
                    updateActions(foundInstance)
                end
            })
            table.insert(explorerElements, button)
        end
    else
        ExplorerSection:CreateLabel({Name = "Nenhuma instância encontrada."})
    end
end

-- RemoteSpy Functions
local function logRemoteCall(remote, direction, ...)
    local args = {...}
    local argStrings = {}
    for i, v in ipairs(args) do
        table.insert(argStrings, tostring(v))
    end
    local logEntry = string.format("[%s] %s %s: %s", os.date("%H:%M:%S"), direction, remote:GetFullName(), table.concat(argStrings, ", "))
    table.insert(remoteSpyLogs, 1, logEntry)
    if #remoteSpyLogs > 50 then
        table.remove(remoteSpyLogs)
    end
    updateRemoteSpyDisplay()
end

local function updateRemoteSpyDisplay()
    if not RemoteSpySection then return end
    remoteSpyElements = clearSection(RemoteSpySection, remoteSpyElements)
    for _, log in ipairs(remoteSpyLogs) do
        local label = RemoteSpySection:CreateLabel({Name = log})
        table.insert(remoteSpyElements, label)
    end
end

local function hookRemote(remote)
    if remote:IsA("RemoteEvent") then
        local originalFireServer = remote.FireServer
        remote.FireServer = function(self, ...)
            logRemoteCall(self, "FireServer", ...)
            return originalFireServer(self, ...)
        end

        local originalFireClient = remote.FireClient
        remote.FireClient = function(self, player, ...)
            logRemoteCall(self, "FireClient", player.Name, ...)
            return originalFireClient(self, player, ...)
        end
    elseif remote:IsA("RemoteFunction") then
        local originalInvokeServer = remote.InvokeServer
        remote.InvokeServer = function(self, ...)
            logRemoteCall(self, "InvokeServer", ...)
            return originalInvokeServer(self, ...)
        end

        local originalInvokeClient = remote.InvokeClient
        remote.InvokeClient = function(self, player, ...)
            logRemoteCall(self, "InvokeClient", player.Name, ...)
            return originalInvokeClient(self, player, ...)
        end
    end
end

local function startRemoteSpy()
    if not RemoteSpySection then return end
    for _, service in pairs(game:GetChildren()) do
        for _, remote in pairs(service:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                hookRemote(remote)
            end
        end
    end
    game.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") then
            hookRemote(descendant)
        end
    end)
    RemoteSpySection:CreateLabel({Name = "RemoteSpy Ativo! Monitorando Remotes."})
end

-- Script Decompiler/Viewer Functions
local function viewScriptSource(scriptInstance)
    if not ScriptSourceSection then return end
    scriptElements = clearSection(ScriptSourceSection, scriptElements)

    local source = "Não foi possível obter o código-fonte." -- Default message
    local success, scriptContent = pcall(function() return scriptInstance.Source end)

    if success and scriptContent then
        source = scriptContent
    elseif syn and syn.decompile then
        local decompileSuccess, decompiledSource = pcall(function() return syn.decompile(scriptInstance) end)
        if decompileSuccess and decompiledSource then
            source = decompiledSource
        else
            source = "Falha ao descompilar com syn.decompile: " .. (decompiledSource or "Erro desconhecido")
        end
    else
        source = "Decompilação não suportada ou falhou. Tente com um executor que suporte \'syn.decompile\'."
    end

    local displaySource = source
    local maxDisplayLength = 500
    if #source > maxDisplayLength then
        displaySource = source:sub(1, maxDisplayLength) .. "\n... (código truncado, muito longo para exibir completamente)"
    end

    if currentScriptSourceLabel then
        pcall(function() currentScriptSourceLabel:Destroy() end)
    end

    currentScriptSourceLabel = ScriptSourceSection:CreateInput({
        Name = scriptInstance.Name .. " Source",
        CurrentValue = displaySource,
        PlaceholderText = "Código-fonte do script",
        RemoveTextAfterFocusLost = false,
        -- MultiLine = true, -- Rayfield CreateInput pode não suportar
        Callback = function(newSource)
        end
    })
    table.insert(scriptElements, currentScriptSourceLabel)
end

local function updateScriptsList()
    if not ScriptsListSection then return end
    scriptElements = clearSection(ScriptsListSection, scriptElements)

    local allScripts = {}
    for _, descendant in pairs(game:GetDescendants()) do
        if descendant:IsA("LocalScript") or descendant:IsA("ModuleScript") or descendant:IsA("Script") then
            table.insert(allScripts, descendant)
        end
    end

    if #allScripts > 0 then
        for _, scriptInstance in ipairs(allScripts) do
            local scriptButton = ScriptsListSection:CreateButton({
                Name = scriptInstance.Name .. " (" .. scriptInstance.ClassName .. ")",
                Callback = function()
                    viewScriptSource(scriptInstance)
                end
            })
            table.insert(scriptElements, scriptButton)
        end
    else
        ScriptsListSection:CreateLabel({Name = "Nenhum script encontrado."})
    end
end

