-- Função segura para criar abas
local function safeCreateTab(name, icon)
    local tabSuccess, tab = pcall(function()
        return Window:CreateTab(name, icon)
    end)
    if tabSuccess and tab then
        print("[Manus Explorer] Aba criada: " .. name)
        return tab
    else
        warn("[Manus Explorer] Falha ao criar aba " .. name .. ": " .. tostring(tab))
        return nil
    end
end

